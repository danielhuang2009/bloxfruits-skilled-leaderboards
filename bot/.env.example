# ===========================================================================
# Discord Leaderboard Bot — environment configuration
# Copy this file to ".env" and fill in real values. Never commit the real .env.
# ===========================================================================

# --- Discord ---------------------------------------------------------------
# Bot token from the Discord Developer Portal (Application > Bot > Reset Token).
DISCORD_TOKEN=

# OPTIONAL: a single guild (server) ID. When set, slash commands are synced to
# this guild and become available INSTANTLY. Leave blank for global commands
# (these can take up to ~1 hour to appear). Enable Developer Mode in Discord,
# right-click your server > "Copy Server ID".
DISCORD_GUILD_ID=

# --- GitHub ----------------------------------------------------------------
# A token with WRITE (Contents: Read and write) access to the repository.
# Fine-grained PAT recommended — scope it to just this repo.
GITHUB_TOKEN=

# Repository owner (user or org) and repository name.
GITHUB_OWNER=danielhuang2009
GITHUB_REPO=bloxfruits-skilled-leaderboards

# OPTIONAL: branch to commit to. Leave blank to use the repo's default branch.
GITHUB_BRANCH=

# Path to the players JSON file within the repository.
PLAYERS_FILE_PATH=players.json

# --- Access control --------------------------------------------------------
# Discord role ID allowed to use mutating commands. Enable Developer Mode,
# then Server Settings > Roles > right-click a role > "Copy Role ID".
# (Guild Administrators are also always allowed.)
ADMIN_ROLE_ID=
